    "distinct_country_count": {
      "type": "number",
      "default": 0,
      "description": "\u76ee\u7684\u56fd\u79cd\u7c7b\u6570"
    },
    "last_scan_at": {
      "type": "string",
      "description": "\u6700\u8fd1\u5168\u91cf\u626b\u63cf\u65f6\u95f4\uff08ISO\uff09"
    },
    "last_event_at": {
      "type": "string",
      "description": "\u6700\u8fd1\u4e8b\u4ef6\u9a71\u52a8\u66f4\u65b0\u65f6\u95f4\uff08ISO\uff09"
    },
    "last_update_source": {
      "type": "string",
      "enum": [
        "scan",
        "event"
      ],
      "description": "\u6700\u8fd1\u66f4\u65b0\u6765\u6e90"
    }
  },
  "required": [
    "tenant_id",
    "user_email"
  ]
}